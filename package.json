{
  "name": "selftend",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "expo start",
    "start:dev-client": "node scripts/start-dev-client.js",
    "android": "node scripts/android-dev.js",
    "android:dev": "node scripts/android-dev.js",
    "android:dev-server": "node scripts/android-dev.js",
    "android:studio": "node scripts/android-dev.js",
    "android:server-only": "node scripts/android-dev.js --no-launch",
    "android:emulator": "node scripts/android-dev.js --emulator-only",
    "android:emulator:list": "node scripts/android-dev.js --list-avds",
    "android:expo-go": "expo start --android",
    "build:android:development": "npm exec eas-cli -- build --platform android --profile development",
    "build:android:development:local": "npm exec --yes eas-cli -- build --platform android --profile development --local",
    "build:android:preview": "npm exec eas-cli -- build --platform android --profile preview",
    "build:android:production": "npm exec eas-cli -- build --platform android --profile production",
    "submit:android:production": "npm exec eas-cli -- submit --platform android --profile production",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "export:web": "npm exec expo -- export --platform web --clear",
    "deploy": "npm run export:web && npm exec netlify-cli -- deploy --prod --dir=dist",
    "serve:web:production": "npm exec expo -- serve",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "verify": "npm run lint && npm run format:check && npm run typecheck && npm test -- --runInBand",
    "prepare": "husky"
  },
  "dependencies": {
    "@expo-google-fonts/noto-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@rn-primitives/accordion": "^1.4.0",
    "@rn-primitives/alert-dialog": "^1.4.0",
    "@rn-primitives/aspect-ratio": "^1.4.0",
    "@rn-primitives/avatar": "^1.4.0",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/collapsible": "^1.4.0",
    "@rn-primitives/context-menu": "^1.4.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/dropdown-menu": "^1.4.0",
    "@rn-primitives/hover-card": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/menubar": "^1.4.0",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/portal": "^1.4.0",
    "@rn-primitives/progress": "^1.4.0",
    "@rn-primitives/radio-group": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "@rn-primitives/toggle-group": "^1.4.0",
    "@rn-primitives/tooltip": "^1.4.0",
    "@supabase/supabase-js": "^2.103.2",
    "@tanstack/react-query": "^5.99.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^26.0.8",
    "lucide-react-native": "^1.14.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-easy-crop": "^5.5.7",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.6",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest-expo": "~54.0.17",
    "prettier": "^3.8.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
