# Local Supabase development env. Copy to `.env.local` and fill in the anon key.
# Expo's dev transform merges every `.env*` file over process.env with
# `.env.local` winning, so this is what the dev client actually uses.
# Points the app at the local Supabase stack started with `npm run db:start`.
#
# Get the local anon key by running: `npm run db:status`
# (look for "anon key" in the output).
#
# Pick the right host for SUPABASE_URL based on how the phone reaches Metro:
#
#   1. USB-connected Android device or emulator
#      → Use `http://localhost:54321`. `npm run start` /
#        `npm run start:emulator` run `adb reverse` automatically so localhost
#        on the device forwards to your machine. Requires the phone to appear
#        in `adb devices`.
#
#   2. Wi-Fi only (QR code scan from a phone not on USB)
#      → Use your dev machine's LAN IP, e.g. `http://192.168.0.20:54321`.
#        Find yours with `ip -4 -o addr show` (Linux) or `ipconfig getifaddr en0`
#        (macOS). Supabase CLI binds the API to 0.0.0.0 so LAN clients can reach
#        it directly; no `adb reverse` needed. Caveat: Google OAuth won't work
#        because supabase/config.toml hardcodes the localhost callback.
#        If your LAN IP changes (new network, DHCP), update this file.
#
#   3. Android emulator without adb reverse → `http://10.0.2.2:54321`.

EXPO_PUBLIC_SUPABASE_URL=http://localhost:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_PUBLIC_APP_URL=http://localhost:8081

# Optional - only set if you wired up a dev Google OAuth client for local testing.
# See supabase/README.md "Local development" for the steps.
# GOOGLE_LOCAL_CLIENT_ID=
# GOOGLE_LOCAL_CLIENT_SECRET=
